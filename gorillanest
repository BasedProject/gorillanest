#!/usr/bin/env bash

cd "$(dirname "$(readlink -f "$0")")"
source venv/bin/activate

pids=()
function superwise_process() {
    $@ &
    pids+=($!)
}
function cleanup() {
    for pid in "${pids[@]}"; do
        if kill -0 "$pid" 2>/dev/null; then
            kill -TERM "$pid"
        fi
    done
    wait
}
trap cleanup INT TERM EXIT

superwise_process gn-daemon
superwise_process gn-web

wait "${pids[@]}"
