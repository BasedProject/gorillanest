<html>
[% title = "/${username}/${repository}" %]
[% INCLUDE head.tt %]
<body>
  <h1>[% title %]</h1>
  <p>Branches:</p>
  <ul>
    [% FOREACH k IN h_repository.branches.keys %]
      <li>[% k %]</li>
    [% END %]
  </ul>
  <p>Files:</p>
  <ul>
    [% FOR i IN h_repository.files %]
      <li>[% i %]</li>
    [% END %]
  </ul>
</body>
[% INCLUDE footer.tt %]
</html>
